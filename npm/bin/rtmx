#!/usr/bin/env node
// Wrapper script that finds and executes the rtmx Go binary.

"use strict";

const path = require("path");
const { execFileSync } = require("child_process");
const os = require("os");

const binaryName = os.platform() === "win32" ? "rtmx.exe" : "rtmx";
const binaryPath = path.join(__dirname, binaryName);

try {
  execFileSync(binaryPath, process.argv.slice(2), { stdio: "inherit" });
} catch (err) {
  if (err.status !== undefined) {
    process.exit(err.status);
  }
  console.error("Failed to run rtmx binary. Try reinstalling:");
  console.error("  npm install -g rtmx");
  process.exit(1);
}
